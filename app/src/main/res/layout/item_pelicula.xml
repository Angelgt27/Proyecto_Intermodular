<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@color/blanco"
    android:elevation="2dp"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivPeliculaWIP"
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@color/gris_claro_borde"
        android:scaleType="centerInside"
        android:src="@drawable/ic_wip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@drawable/ic_wip" />
    <TextView
        android:id="@+id/tvTituloPelicula"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Título Película"
        android:textColor="@color/negro"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivPeliculaWIP"
        app:layout_constraintTop_toTopOf="@id/ivPeliculaWIP" />

    <TextView
        android:id="@+id/tvDescripcionPelicula"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:text="Descripción corta de la película, género, duración, etc. Esto puede ocupar varias líneas."
        android:textColor="@color/gris_oscuro"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvTituloPelicula"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPelicula" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReservarItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Reservar"
        android:textAllCaps="false"
        android:textColor="@color/blanco"
        app:backgroundTint="@color/gris_oscuro"
        app:cornerRadius="8dp"
        app:layout_constraintStart_toStartOf="@id/tvTituloPelicula"
        app:layout_constraintTop_toBottomOf="@id/tvDescripcionPelicula"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>